# Copy this file to ".env" (same folder) and fill in values to enable real
# email sending. Leave it absent/unset to stay in demo mode, where emails are
# logged to the server console and stored in the email_outbox table.
#
#   cp .env.example .env      (macOS/Linux)
#   copy .env.example .env    (Windows)
#
# .env is gitignored, so your secrets are never committed.

# ---- Email (SMTP) — Gmail example -----------------------------------------
# For Gmail you must enable 2-Step Verification and create an App Password:
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=prakashatinfo@gmail.com
SMTP_PASS=
SMTP_FROM=prakashatinfo@gmail.com

# ---- Optional ---------------------------------------------------------------
# Auto-approve a Sick leave left pending longer than this many days.
AUTO_APPROVE_SICK_DAYS=3

# Force the offline (rule-based) parser and skip the Claude probe:
# LEAVE_OFFLINE=1
